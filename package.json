{
  "name": "teamassistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite --config frontend/vite.config.ts --host 127.0.0.1",
    "dev:legacy": "node legacy-node/server.js",
    "backend:configure": "cmake -S backend-cpp -B backend-cpp/build",
    "backend:build": "cmake --build backend-cpp/build",
    "backend:serve": "node scripts/serve-backend-cpp.mjs",
    "build": "tsc -b frontend && vite build --config frontend/vite.config.ts",
    "serve": "node scripts/serve-backend-cpp.mjs",
    "lint": "eslint -c frontend/eslint.config.js frontend",
    "preview": "vite preview --config frontend/vite.config.ts",
    "test": "node --import tsx --test frontend/test/*.test.mjs",
    "test:e2e": "node frontend/test/slot-grid-playwright.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "level": "^10.0.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
